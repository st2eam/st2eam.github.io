{
  "name": "st2eam-github-io",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:docs": "npm run clean:docs && npm run build",
    "clean:docs": "rimraf docs",
    "preview": "vite preview",
    "photos": "node scripts/compress-photos.cjs && node scripts/sync-photos.cjs",
    "photos:sync": "node scripts/sync-photos.cjs",
    "photos:compress": "node scripts/compress-photos.cjs",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,less,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,less,md}\""
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/lab": "^9.0.0-beta.2",
    "@mui/material": "^9.0.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.22.3",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "exifr": "^7.1.3",
    "less": "^4.2.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.6.0",
    "undici": "^8.1.0",
    "vite": "^6.3.0"
  }
}
